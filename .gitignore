# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/

# Secrets
.env

# Data and outputs — keep .gitkeep sentinels, ignore everything else
data/inputs/*
!data/inputs/.gitkeep
data/cache/*
!data/cache/.gitkeep
!data/cache/articles/
!data/cache/articles/*.json
outputs/*
!outputs/.gitkeep
!outputs/style_audit.json
!outputs/style_audit.md
!outputs/disclosure_url_audit.md
