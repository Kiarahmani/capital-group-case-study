# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/

# OS cruft
.DS_Store
**/.DS_Store

# Virtual environments
.venv/
venv/
env/

# Secrets
.env

# Data and outputs — keep .gitkeep sentinels, ignore everything else
data/inputs/*
!data/inputs/.gitkeep
data/cache/*
!data/cache/.gitkeep
!data/cache/articles/
!data/cache/articles/*.json
!data/cache/eval_articles/
!data/cache/eval_articles/*.json
!data/cache/embeddings.npz
!data/cache/embeddings_meta.json
outputs/*
!outputs/.gitkeep
!outputs/style_audit.json
!outputs/style_audit.md
!outputs/disclosure_url_audit.md
# Deliverable artifacts ship via email, not the repo:
#   - outputs/gen_*_posts.csv / .xlsx (THE submission spreadsheet)
#   - outputs/one_pager.pdf (formatted writeup for email)
# Engineering evidence stays in the repo:
!outputs/gen_*_trace.jsonl
!outputs/eval_*.csv
!outputs/eval_*.md
!outputs/one_pager.txt
